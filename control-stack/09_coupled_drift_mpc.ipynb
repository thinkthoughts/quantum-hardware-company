# ============================================================
# 09 — Coupled Drift MPC vs Kalman (Ω + B interaction)
# ============================================================

import numpy as np
import matplotlib.pyplot as plt
import os

# -------------------------------
# Setup
# -------------------------------

np.random.seed(42)

FIG_DIR = "figures/coupled_drift_mpc"
os.makedirs(FIG_DIR, exist_ok=True)

def save_fig(name):
    base = f"09_coupled_drift_mpc_{name}"
    plt.savefig(f"{FIG_DIR}/{base}.png", dpi=150, bbox_inches="tight")
    plt.savefig(f"{FIG_DIR}/{base}.pdf", bbox_inches="tight")

# -------------------------------
# Simulation parameters
# -------------------------------

T = 50
t = np.arange(T)

# Fast + coupled drift
true_omega = 0.08 * np.sin(0.35 * t) + 0.02 * np.sin(0.9 * t)
true_B     = 0.05 * np.cos(0.25 * t) + 0.015 * true_omega

sigma_omega = 0.004
sigma_B     = 0.006

meas_omega = true_omega + np.random.normal(0, sigma_omega, T)
meas_B     = true_B     + np.random.normal(0, sigma_B, T)

# -------------------------------
# Signal model (excited-state)
# -------------------------------

def signal(omega, B, x):
    return 0.5 * (1 + np.sin(omega * x + B))

x_axis = np.linspace(0, 10, 200)

target = signal(true_omega[:, None], true_B[:, None], x_axis)

# -------------------------------
# Estimators
# -------------------------------

# Moving average
def moving_avg(x, k=3):
    out = np.copy(x)
    for i in range(k, len(x)):
        out[i] = np.mean(x[i-k:i])
    return out

ma_omega = moving_avg(meas_omega)
ma_B     = moving_avg(meas_B)

# Scalar Kalman
def scalar_kalman(z, q=1e-5, r=1e-3):
    x = 0
    P = 1
    xs = []
    for zi in z:
        # predict
        P = P + q
        # update
        K = P / (P + r)
        x = x + K * (zi - x)
        P = (1 - K) * P
        xs.append(x)
    return np.array(xs)

sk_omega = scalar_kalman(meas_omega)
sk_B     = scalar_kalman(meas_B)

# Joint Kalman (2D)
def joint_kalman(z1, z2, q=1e-5, r=1e-3):
    x = np.array([0.0, 0.0])
    P = np.eye(2)
    xs = []

    for i in range(len(z1)):
        # predict
        P = P + q * np.eye(2)

        z = np.array([z1[i], z2[i]])
        K = P @ np.linalg.inv(P + r * np.eye(2))

        x = x + K @ (z - x)
        P = (np.eye(2) - K) @ P

        xs.append(x.copy())

    return np.array(xs)

jk = joint_kalman(meas_omega, meas_B)
jk_omega = jk[:, 0]
jk_B     = jk[:, 1]

# -------------------------------
# Naive predictive (bad baseline)
# -------------------------------

naive_omega = np.roll(meas_omega, 1)
naive_B     = np.roll(meas_B, 1)

# -------------------------------
# Coupled MPC (constraint-aware)
# -------------------------------

def coupled_mpc(meas_omega, meas_B, lam=50, bound=0.02):
    omega = np.copy(meas_omega)
    B     = np.copy(meas_B)

    for i in range(1, len(omega)):
        dω = omega[i] - omega[i-1]
        dB = B[i]     - B[i-1]

        # penalize large jumps
        dω = np.clip(dω, -bound, bound)
        dB = np.clip(dB, -bound, bound)

        omega[i] = omega[i-1] + (1/(1+lam)) * dω
        B[i]     = B[i-1]     + (1/(1+lam)) * dB

    return omega, B

mpc_omega, mpc_B = coupled_mpc(meas_omega, meas_B)

# -------------------------------
# Responses
# -------------------------------

def build_response(omega, B):
    return signal(omega[:, None], B[:, None], x_axis)

resp_none = build_response(meas_omega, meas_B)
resp_ma   = build_response(ma_omega, ma_B)
resp_sk   = build_response(sk_omega, sk_B)
resp_jk   = build_response(jk_omega, jk_B)
resp_np   = build_response(naive_omega, naive_B)
resp_mpc  = build_response(mpc_omega, mpc_B)

# -------------------------------
# Metrics
# -------------------------------

def rmse(a, b):
    return np.sqrt(np.mean((a - b)**2))

def cosine(a, b):
    a = a.flatten()
    b = b.flatten()
    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))

policies = {
    "none": resp_none,
    "moving_average": resp_ma,
    "scalar_kalman": resp_sk,
    "joint_kalman": resp_jk,
    "naive_predictive": resp_np,
    "coupled_mpc": resp_mpc,
}

metrics = {}
for k, v in policies.items():
    metrics[k] = {
        "mean_rmse": rmse(v, target),
        "cosine": cosine(v, target),
    }

print(metrics)

# -------------------------------
# Plot: Ω tracking
# -------------------------------

plt.figure(figsize=(8,4))
plt.plot(true_omega, label="true Ω")
plt.plot(meas_omega, 'o', alpha=0.4, label="measured Ω")
plt.plot(jk_omega, label="joint Kalman")
plt.plot(mpc_omega, label="coupled MPC")
plt.legend()
plt.title("Coupled drift: Ω tracking")
save_fig("omega_tracking")
plt.show()

# -------------------------------
# Plot: B tracking
# -------------------------------

plt.figure(figsize=(8,4))
plt.plot(true_B, label="true B")
plt.plot(meas_B, 'o', alpha=0.4, label="measured B")
plt.plot(jk_B, label="joint Kalman")
plt.plot(mpc_B, label="coupled MPC")
plt.legend()
plt.title("Coupled drift: B tracking")
save_fig("offset_tracking")
plt.show()

# -------------------------------
# Plot: RMSE over time
# -------------------------------

plt.figure(figsize=(8,4))
for k, v in policies.items():
    errs = [rmse(v[i], target[i]) for i in range(T)]
    plt.plot(errs, label=k)

plt.legend()
plt.title("Coupled drift: response RMSE")
save_fig("response_rmse_comparison")
plt.show()

# -------------------------------
# Plot: CGCS stability
# -------------------------------

plt.figure(figsize=(8,4))
for k, v in policies.items():
    cos_vals = [cosine(v[i], target[i]) for i in range(T)]
    plt.plot(cos_vals, label=k)

plt.axhline(1/np.sqrt(2), linestyle='--', label="45° threshold")
plt.legend()
plt.title("Coupled drift: CGCS phase-lock")
save_fig("cgcs_stability")
plt.show()
